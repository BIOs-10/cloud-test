services:
  mysql:
    image: mysql:8.0
    restart: unless-stopped
    environment:
      MYSQL_ROOT_PASSWORD: ${MYSQL_ROOT_PASSWORD}
      MYSQL_DATABASE: ${MYSQL_DATABASE}
      MYSQL_USER: ${MYSQL_USER}
      MYSQL_PASSWORD: ${MYSQL_PASSWORD}
    volumes:
      - mysql_data_{{ username }}:/var/lib/mysql
    networks:
      - proxy

  phpmyadmin:
    image: phpmyadmin:latest
    restart: unless-stopped
    depends_on:
      - mysql
    environment:
      PMA_HOST: mysql
      PMA_PORT: 3306
      UPLOAD_LIMIT: 100M
    networks:
      - proxy
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.pma{{ username }}.rule=Host(`{{ username }}-pma.icube.local`)"
      - "traefik.http.routers.pma{{ username }}.entrypoints=web"
      - "traefik.http.services.pma{{ username }}.loadbalancer.server.port=80"

networks:
  proxy:
    external: true

volumes:
  mysql_data_{{ username }}:
